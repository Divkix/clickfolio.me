{
  "name": "clickfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3000",
    "build": "vp build",
    "build:worker": "vp build",
    "start": "vp preview",
    "lint": "vp lint",
    "fix": "vp check --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next dist",
    "test": "vp test run",
    "test:unit": "vp test run --config vitest.unit.config.ts",
    "test:integration": "vp test run --config vitest.integration.config.ts",
    "test:security": "vp test run --config vitest.security.config.ts",
    "test:coverage": "vp test run --coverage",
    "test:ci": "vp test run --coverage --reporter=json",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "ci": "bun install --frozen-lockfile && bun run type-check && vp check && bun run test && bun run build",
    "preview": "vp build && bunx wrangler dev",
    "deploy": "bun run scripts/deploy.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "wrangler d1 migrations apply clickfolio-db --local",
    "db:migrate:prod": "bun run scripts/migrate-prod.ts",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && bun run db:migrate",
    "db:studio": "drizzle-kit studio --port 4984",
    "analyze": "ANALYZE=true vp build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv lib/cloudflare-env.d.ts",
    "generate:favicons": "bun run scripts/generate-favicons.ts",
    "db:seed:local": "bun run scripts/seed-local.ts",
    "db:reset:local": "bun run db:reset && bun run db:seed:local",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@better-auth/drizzle-adapter": "^1.6.16",
    "@cf-wasm/resvg": "^0.3.3",
    "@hookform/resolvers": "^5.4.0",
    "@neoconfetti/react": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-progress": "^1.1.9",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-switch": "^1.3.0",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "ai": "^6.0.201",
    "better-auth": "^1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.78.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unpdf": "^1.6.2",
    "uplot": "^1.6.32",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.40.1",
    "@noble/hashes": "^2.2.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.27",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.0",
    "tailwindcss": "^4.3.0",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vinext": "^0.1.1",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.99.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "bun@1.3.14"
}
