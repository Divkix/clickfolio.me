{
  "name": "clickfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build:worker": "vite build",
    "start": "vite preview",
    "lint": "biome check .",
    "fix": "biome check --write .",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next dist",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=json",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "ci": "bun run type-check && bun run lint && bun run test && bun run build",
    "preview": "vite build && bunx wrangler dev",
    "deploy": "bun run scripts/deploy.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "wrangler d1 migrations apply clickfolio-db --local",
    "db:migrate:prod": "bun run scripts/migrate-prod.ts",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && bun run db:migrate",
    "db:studio": "drizzle-kit studio --port 4984",
    "analyze": "ANALYZE=true vite build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv lib/cloudflare-env.d.ts",
    "generate:favicons": "bun run scripts/generate-favicons.ts",
    "db:seed:local": "bun run scripts/seed-local.ts",
    "db:reset:local": "bun run db:reset && bun run db:seed:local",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.40",
    "@better-auth/drizzle-adapter": "^1.6.0",
    "@hookform/resolvers": "^5.2.2",
    "@neoconfetti/react": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "@zxcvbn-ts/language-en": "^3.0.2",
    "ai": "^6.0.149",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "^16.2.2",
    "next-themes": "^0.4.6",
    "ofetch": "^1.5.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "unpdf": "^1.4.0",
    "uplot": "^1.6.32",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@noble/hashes": "^2.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.22",
    "@vitest/coverage-v8": "^4.1.2",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "to-ico": "^1.1.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vinext": "^0.0.39",
    "vite": "^8.0.5",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  },
  "type": "module"
}
