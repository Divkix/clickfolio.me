{
  "name": "clickfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev --port 3000",
    "build": "vp build",
    "build:worker": "vp build",
    "start": "vp preview",
    "lint": "vp lint",
    "fix": "vp check --fix",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next dist",
    "test": "vp test run",
    "test:unit": "vp test run --config vitest.unit.config.ts",
    "test:integration": "vp test run --config vitest.integration.config.ts",
    "test:security": "vp test run --config vitest.security.config.ts",
    "test:coverage": "vp test run --coverage",
    "test:ci": "vp test run --coverage --reporter=json",
    "test:watch": "vp test",
    "test:ui": "vp test --ui",
    "ci": "pnpm install --frozen-lockfile && pnpm run type-check && vp check && pnpm run test && pnpm run build",
    "preview": "vp build && pnpm exec wrangler dev",
    "deploy": "tsx scripts/deploy.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "wrangler d1 migrations apply clickfolio-db --local",
    "db:migrate:prod": "tsx scripts/migrate-prod.ts",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && pnpm run db:migrate",
    "db:studio": "drizzle-kit studio --port 4984",
    "analyze": "ANALYZE=true vp build",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv lib/cloudflare-env.d.ts",
    "generate:favicons": "tsx scripts/generate-favicons.ts",
    "db:seed:local": "tsx scripts/seed-local.ts",
    "db:reset:local": "pnpm run db:reset && pnpm run db:seed:local",
    "prepare": "vp config"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^3.0.13",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@cf-wasm/resvg": "^0.3.5",
    "@fontsource-variable/bricolage-grotesque": "^5.3.0",
    "@fontsource-variable/hanken-grotesk": "^5.3.0",
    "@fontsource-variable/jetbrains-mono": "^5.3.0",
    "@hookform/resolvers": "^5.4.0",
    "@neoconfetti/react": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-progress": "^1.1.13",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.4",
    "@zxcvbn-ts/core": "^4.1.2",
    "@zxcvbn-ts/language-common": "^4.1.3",
    "@zxcvbn-ts/language-en": "^4.1.1",
    "ai": "^7.0.32",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.25.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.405.2",
    "posthog-node": "^5.46.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "unpdf": "^1.6.2",
    "uplot": "^1.6.32",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@noble/hashes": "^2.2.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-rsc": "^0.5.28",
    "@vitest/coverage-v8": "4.1.10",
    "better-sqlite3": "^13.0.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.1.1",
    "knip": "^6.27.0",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "postcss": "^8.5.20",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^7.0.2",
    "vinext": "1.0.0-beta.2",
    "vite": "catalog:",
    "vite-plus": "^0.2.5",
    "vitest": "catalog:",
    "wrangler": "^4.112.0"
  },
  "packageManager": "pnpm@11.10.0"
}
