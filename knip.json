{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": ["scripts/**/*.ts"],
  "project": [
    "app/**/*.{ts,tsx}",
    "components/**/*.{ts,tsx}",
    "hooks/**/*.{ts,tsx}",
    "lib/**/*.{ts,tsx}"
  ],
  "ignore": [
    "components/blog/HighlightBlock.tsx",
    "lib/db/schema/**",
    "lib/db/schema/relations.ts"
  ],
  "ignoreBinaries": [],
  "ignoreDependencies": [
    "cloudflare",
    "postcss",
    "tailwindcss",
    "tw-animate-css",
    "@tailwindcss/typography"
  ],
  "ignoreExportsUsedInFile": true
}
